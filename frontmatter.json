{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.content.autoUpdateDate": true,
  "frontMatter.content.pageFolders": [
    {
      "contentTypes": ["post"],
      "excludeSubdir": true,
      "path": "[[workspace]]/contents/posts",
      "title": "posts"
    }
  ],
  "frontMatter.content.publicFolder": "public",
  "frontMatter.data.files": [
    {
      "file": "[[workspace]]/contents/metadata.json",
      "fileType": "json",
      "id": "metadata",
      "labelField": "title",
      "schema": {
        "properties": {
          "title": {
            "title": "Title",
            "type": "string"
          },
          "creator": {
            "title": "Creator",
            "type": "string"
          },
          "description": {
            "title": "Description",
            "type": "string"
          },
          "host": {
            "title": "Host",
            "type": "string"
          }
        },
        "required": ["title", "creator", "description", "host"],
        "title": "Metadata",
        "type": "object"
      },
      "singleEntry": true,
      "title": "Metadata"
    }
  ],
  "frontMatter.framework.id": "next",
  "frontMatter.taxonomy.contentTypes": [
    {
      "fields": [
        {
          "name": "title",
          "title": "Title",
          "type": "string"
        },
        {
          "dateFormat": "YYYY-MM-dd",
          "default": "{{now}}",
          "isPublishDate": true,
          "name": "date",
          "title": "Creation date",
          "type": "datetime"
        },
        {
          "dateFormat": "YYYY-MM-dd",
          "isModifiedDate": true,
          "name": "lastmod",
          "title": "Last modified date",
          "type": "datetime"
        },
        {
          "name": "draft",
          "title": "Is in draft",
          "type": "draft"
        },
        {
          "name": "tags",
          "title": "Tags",
          "type": "tags"
        }
      ],
      "filePrefix": "",
      "name": "post",
      "previewPath": "posts"
    }
  ]
}
