{
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@builder.io/qwik": "^1.19.1",
    "@builder.io/qwik-city": "^1.19.1",
    "@daiji256/rehype-mathml": "^1.2.2",
    "@shikijs/rehype": "^4.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.0.0",
    "daisyui": "^5.5.19",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.2.1",
    "typescript": "5.4.5",
    "undici": "*",
    "unified": "^11.0.5",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
